# Server Configuration
PORT=3000
DEV=true

# CORS and CSP Frame Ancestors Allowed Origins (comma separated domains, e.g. https://rifatela.com)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000



# RapidAPI Hub - BuiltWith Domain Integration
# Subscribe to the API at rapidapi.com/builtwith-builtwith-default/api/builtwith-domain/
RAPIDAPI_KEY=

# Logo.dev Integration (Publishable Key pk_...)
# Get your API key at logo.dev
LOGODEV_PUBLISHABLE_KEY=

# Logo.dev Secret API Key (Used for server-side search/profile REST APIs)
LOGODEV_SECRET_KEY=

# Screenshot Machine Customer Key
# Get your customer key at screenshotmachine.com
SCREENSHOTMACHINE_KEY=

# SMTP Mail Server Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME="Rífatela Detector"

# Application Base URL (for absolute links in emails and embed codes)
APP_URL=http://localhost:3000

