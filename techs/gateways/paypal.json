{
  "name": "PayPal",
  "category": "Payment Gateway",
  "web": "https://paypal.com",
  "logo": "paypal.com",
  "detectionRules": [
    {
      "type": "script-src",
      "pattern": "paypal\\.com/sdk/js|checkout\\.js|paypal-objects",
      "description": "Script de integración de PayPal detectado"
    },
    {
      "type": "html",
      "pattern": "payment_method_paypal|\\bpaypal\\b|\\bpay-pal\\b",
      "description": "Clase o marca HTML de PayPal detectada"
    }
  ]
}