{
  "name": "Webpay",
  "category": "Payment Gateway",
  "web": "https://www.transbank.cl",
  "logo": "webpay.cl",
  "detectionRules": [
    {
      "type": "script-src",
      "pattern": "webpay\\.js",
      "description": "Script de integración de Webpay detectado"
    },
    {
      "type": "html",
      "pattern": "\\bwebpay\\b",
      "description": "Clase o marca HTML de Webpay detectada"
    }
  ]
}