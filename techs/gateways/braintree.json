{
	"name": "Braintree",
	"category": "Payment Gateway",
	"web": "https://braintreepayments.com",
	"logo": "braintreepayments.com",
	"detectionRules": [
		{
			"type": "script-src",
			"pattern": "braintreegateway\\.com|braintree\\.js",
			"description": "Script de integración de Braintree detectado"
		},
		{
			"type": "html",
			"pattern": "\\bbraintree\\b",
			"description": "Clase o marca HTML de Braintree detectada"
		}
	]
}
