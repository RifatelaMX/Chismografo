{
	"name": "Varnish",
	"category": "Cache / Proxy",
	"web": "https://varnish-cache.org",
	"logo": "varnish-cache.org",
	"detectionRules": [
		{
			"type": "header",
			"key": "via",
			"pattern": "varnish",
			"description": "Via header contains varnish cache"
		},
		{
			"type": "header",
			"key": "x-varnish",
			"pattern": ".*",
			"description": "X-Varnish ID header present"
		}
	]
}
