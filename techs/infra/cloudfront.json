{
  "name": "Amazon CloudFront",
  "category": "CDN / Cloud",
  "web": "https://aws.amazon.com/cloudfront",
  "logo": "aws.amazon.com",
  "detectionRules": [
    {
      "type": "header",
      "key": "x-amz-cf-id",
      "pattern": ".*",
      "description": "Amazon CloudFront request ID header present"
    },
    {
      "type": "header",
      "key": "via",
      "pattern": "cloudfront",
      "description": "Via header contains cloudfront"
    }
  ]
}
