{
	"name": "chismografo",
	"version": "1.0.1",
	"description": "Chismógrafo es una aplicación para obtener la pila tecnológica de un sitio web.",
	"repository": {
		"type": "git",
		"url": "https://github.com/cesar-ayar/Chismografo"
	},
	"type": "module",
	"main": "server.js",
	"bin": {
		"chismografo": "./cli/bin/index.js"
	},
	"scripts": {
		"start": "node server.js",
		"dev": "chismografo dev",
		"maildev": "maildev",
		"cli": "chismografo",
		"build": "node ./cli/bin/index.js build-index",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"release": "semantic-release"
	},
	"keywords": [
		"scraper",
		"ecommerce",
		"chismografo",
		"shopify",
		"magento",
		"woocommerce",
		"prestashop",
		"vtex",
		"api"
	],
	"author": "Rífatela",
	"license": "AGPL-3.0-only",
	"dependencies": {
		"axios": "^1.7.9",
		"cheerio": "^1.0.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.21.2",
		"geoip-lite": "^2.0.3",
		"morgan": "^1.10.0",
		"nodemailer": "^9.0.3",
		"screenshotmachine": "^2.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.9",
		"@semantic-release/npm": "^13.1.5",
		"maildev": "^2.2.1",
		"semantic-release": "^25.0.5"
	}
}
